# ============================================================
# Environment Variables — COPY FILE NÀY THÀNH .env
# ============================================================
# Hướng dẫn:
#   1. Tạo một bản copy của file này: cp .env.example .env
#   2. Điền API key thật của bạn vào .env
#   3. File .env sẽ KHÔNG bị commit lên Git (đã có trong .gitignore)

# Anthropic API Key — lấy tại https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
